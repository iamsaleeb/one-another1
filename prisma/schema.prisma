generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ATTENDEE
  ORGANISER
  ADMIN
}

enum Cadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  dateOfBirth   DateTime?
  onboardingCompleted Boolean @default(false)
  role          UserRole  @default(ATTENDEE)
  accounts      Account[]
  sessions      Session[]
  events        Event[]   @relation("UserEvents")
  series        Series[]  @relation("UserSeries")
  eventAttendances EventAttendee[]
  churchFollows    ChurchFollower[]
  seriesFollows    SeriesFollower[]
  churchOrganisers ChurchOrganiser[] @relation("UserChurches")
  adminChurches    ChurchAdmin[]     @relation("UserAdminChurches")
  pushTokens              PushToken[]
  scheduledNotifications  ScheduledNotification[]
  notificationPreferences NotificationPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Church {
  id          String  @id @default(cuid())
  name        String
  address     String?
  phone       String?
  website     String?
  description String
  founded     String?
  totalEvents Int

  serviceTimes ServiceTime[]
  followers    ChurchFollower[]
  events       Event[]
  series       Series[]
  organisers   ChurchOrganiser[] @relation("ChurchOrganisers")
  admins       ChurchAdmin[]     @relation("ChurchAdmins")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChurchAdmin {
  userId    String
  churchId  String
  user      User     @relation("UserAdminChurches", fields: [userId], references: [id], onDelete: Cascade)
  church    Church   @relation("ChurchAdmins", fields: [churchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, churchId])
}

model ChurchOrganiser {
  userId    String
  churchId  String
  user      User     @relation("UserChurches", fields: [userId], references: [id], onDelete: Cascade)
  church    Church   @relation("ChurchOrganisers", fields: [churchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, churchId])
}

model ServiceTime {
  id       String @id @default(cuid())
  day      String
  time     String
  type     String
  churchId String
  church   Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
}

model Series {
  id          String   @id @default(cuid())
  name        String
  description String
  cadence     Cadence
  location    String
  host        String
  tag         String
  photoUrl    String?
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Restrict)
  events      Event[]
  followers   SeriesFollower[]
  createdById String?
  createdBy   User?    @relation("UserSeries", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id                   String  @id @default(cuid())
  datetime             DateTime
  title                String
  location             String
  host                 String
  tag                  String
  description          String
  photoUrl             String?
  isPast               Boolean @default(false)
  isDraft              Boolean @default(false)
  requiresRegistration Boolean @default(false)
  capacity             Int?
  collectPhone         Boolean @default(false)
  collectNotes         Boolean @default(false)
  price                String?
  cancelledAt          DateTime?
  cancellationReason   String?
  churchId             String?
  church               Church? @relation(fields: [churchId], references: [id], onDelete: SetNull)
  seriesId             String?
  series               Series? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  createdById          String?
  createdBy            User?   @relation("UserEvents", fields: [createdById], references: [id], onDelete: SetNull)
  attendees            EventAttendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model ChurchFollower {
  id        String   @id @default(cuid())
  churchId  String
  userId    String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([churchId, userId])
}

model SeriesFollower {
  id        String   @id @default(cuid())
  seriesId  String
  userId    String
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([seriesId, userId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
}

model ScheduledNotification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  eventId      String?
  scheduledFor DateTime
  sentAt       DateTime?
  cancelledAt  DateTime?
  payload      Json
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@unique([userId, type, eventId])
  @@index([scheduledFor, sentAt, cancelledAt])
}

model NotificationPreference {
  id      String  @id @default(cuid())
  userId  String
  type    String
  enabled Boolean @default(true)
  config  Json?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}
